# 心灵伙伴 - 环境变量配置示例
# 复制这份文件为 .env，然后填写实际值

# MiniMax API 配置（必须）
MINIMAX_API_KEY=你的MiniMax_API密钥

# 服务器配置
HOST=0.0.0.0
PORT=8080
DEBUG=True

# 邮件配置（可选，用于危机预警通知）
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ADMIN_EMAIL=

# 管理员账号（建议修改）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# AI模式
AI_MODE=minimax
